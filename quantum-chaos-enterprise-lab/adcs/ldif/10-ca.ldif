# Phase 80 — AD CS chaos lab — CA enrollment service.
#
# One pKIEnrollmentService entry carrying a RSA-1024 SHA-1 cACertificate
# (DER blob committed under adcs/certs/ca-weak.der; base64 inlined below).
# Triggers the weak-signing finding (HIGH) per RESEARCH Pattern 3.
#
# Regenerate via adcs/certs/regen.sh (developer tool only, not runtime).

dn: cn=QuirkLabCA,cn=Enrollment Services,cn=Public Key Services,cn=Services,cn=Configuration,dc=quirk,dc=lab
objectClass: top
objectClass: pKIEnrollmentService
cn: QuirkLabCA
dNSHostName: quirklab.local
cACertificate;binary:: 
