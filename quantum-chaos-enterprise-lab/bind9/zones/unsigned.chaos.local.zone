; unsigned.chaos.local — plain unsigned zone with no DNSSEC records
; DNSSEC-03: Zone with no signing records must produce unsigned-zone finding
; Plain SOA, NS, A only
$TTL 300
$ORIGIN unsigned.chaos.local.

@ IN SOA ns1.unsigned.chaos.local. admin.unsigned.chaos.local. (
    2024010101 ; serial
    3600       ; refresh
    900        ; retry
    604800     ; expire
    300        ; minimum
)

@ IN NS ns1.unsigned.chaos.local.

ns1 IN A 127.0.0.1
@ IN A 127.0.0.1
