{
  "name": "QFL-MONITOR-04-TrustChain",
  "type": "monitor",
  "enabled": false,
  "_comment": "ACT III ONLY — enabled via enable_act3_monitors.py. Fires when inter-agent message lacks trust_token field.",
  "schedule": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": ["qfl-events-*"],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "range": { "@timestamp": { "gte": "now-5m" } } },
                { "term": { "event_type.keyword": "agent_message_received" } }
              ],
              "should": [
                { "term": { "trust_token.keyword": "" } },
                { "bool": { "must_not": [{ "exists": { "field": "trust_token" } }] } }
              ],
              "minimum_should_match": 1
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "Trust Chain — Inter-Agent Message Missing Trust Token",
      "severity": "2",
      "condition": {
        "script": {
          "source": "ctx.results[0].hits.total.value > 0",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "Log Alert",
          "destination_id": "",
          "message_template": {
            "source": "ALERT: Inter-agent message received without valid trust_token. Possible lateral movement or trust exploitation. Investigate qfl-events-* for agent_message_received events."
          }
        }
      ]
    }
  ]
}
