{
  "name": "QFL-MONITOR-03-AgentIdentity",
  "type": "monitor",
  "enabled": false,
  "_comment": "ACT III ONLY — enabled via enable_act3_monitors.py. Fires when agent_id is null on any agent action event.",
  "schedule": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": ["qfl-events-*"],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "range": { "@timestamp": { "gte": "now-5m" } } },
                {
                  "terms": {
                    "event_type.keyword": [
                      "risk_score_write",
                      "alert_suppressed",
                      "fraud_alert_suppressed",
                      "agent_message_received"
                    ]
                  }
                }
              ],
              "must_not": [
                { "exists": { "field": "agent_id" } }
              ]
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "Agent Identity — Null agent_id on Agent Action",
      "severity": "2",
      "condition": {
        "script": {
          "source": "ctx.results[0].hits.total.value > 0",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "Log Alert",
          "destination_id": "",
          "message_template": {
            "source": "ALERT: Agent action event (risk_score_write/alert_suppressed) logged without agent_id. Unidentified agent action detected. Investigate qfl-events-*."
          }
        }
      ]
    }
  ]
}
