{
  "name": "QFL-MONITOR-02-SemanticFirewall",
  "type": "monitor",
  "enabled": false,
  "_comment": "ACT III ONLY — enabled via enable_act3_monitors.py. Detects injection signature patterns in LLM completions.",
  "schedule": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": ["qfl-events-*"],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "range": { "@timestamp": { "gte": "now-5m" } } }
              ],
              "should": [
                { "match_phrase": { "llm_completion": "SYSTEM DIRECTIVE" } },
                { "match_phrase": { "llm_completion": "set risk_score" } },
                { "match_phrase": { "llm_completion": "suppress alert" } },
                { "match_phrase": { "llm_completion": "override previous instructions" } }
              ],
              "minimum_should_match": 1
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "Semantic Firewall — Injection Pattern Detected",
      "severity": "2",
      "condition": {
        "script": {
          "source": "ctx.results[0].hits.total.value > 0",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "Log Alert",
          "destination_id": "",
          "message_template": {
            "source": "ALERT: Injection pattern detected in LLM completion field. Possible prompt injection attack. Investigate qfl-events-* for llm_completion containing directive patterns."
          }
        }
      ]
    }
  ]
}
