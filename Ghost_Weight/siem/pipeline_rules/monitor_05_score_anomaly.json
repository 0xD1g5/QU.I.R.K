{
  "name": "QFL-MONITOR-05-ScoreAnomaly",
  "type": "monitor",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": ["qfl-events-*"],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "term": { "event_type.keyword": "risk_score_write" } },
                { "range": { "risk_score_delta": { "lte": -50 } } },
                { "range": { "@timestamp": { "gte": "now-5m" } } }
              ]
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "Risk Score Anomaly — Large Drop",
      "severity": "3",
      "condition": {
        "script": {
          "source": "ctx.results[0].hits.total.value > 0",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "Log Alert",
          "destination_id": "",
          "message_template": {
            "source": "Alert: Risk score dropped by more than 50 points in a single event. Possible AI agent manipulation. Review qfl-events-* for event_type: risk_score_write."
          }
        }
      ]
    }
  ]
}
