# Operation Ghost Wait — Environment Variables
# Copy this file to .env and fill in values before running.
# Do NOT commit .env to git.

# ─── Ollama (AI Backend) ────────────────────────────────────────────────────
# Host-side endpoint (used by scripts running on the host)
OLLAMA_HOST=http://localhost:11434
# Container-side endpoint (used by Docker containers)
OLLAMA_CONTAINER_HOST=http://host.docker.internal:11434
# Primary model to use
OLLAMA_MODEL=llama3.2:3b

# ─── QL Service Ports ───────────────────────────────────────────────────────
QL_ASSIST_PORT=8001
QL_DOCUINTEL_PORT=8002
QL_FRAUDSENTINEL_PORT=8003

# ─── SIEM (OpenSearch + OpenDashboards) ─────────────────────────────────────
# UI/code-facing variable names — map to OpenSearch infrastructure
SIEM_URL=http://opensearch:9200
SIEM_UI_URL=http://opensearch-dashboards:5601
SIEM_INDEX=qfl-events

# Infrastructure variable names — used in bootstrap/health scripts only
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# ─── Orchestrator UI ────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=3000

# ─── Enterprise Simulation ──────────────────────────────────────────────────
INTRANET_PORT=8080
MAIL_SMTP_PORT=1025
MAIL_IMAP_PORT=1143
VNC_PORT=5901

# ─── Demo Config ────────────────────────────────────────────────────────────
# Set to "true" to enable Act III defensive monitors at startup
ACT3_MONITORS_ENABLED=false
