# QU.I.R.K. console environment file
# -----------------------------------------------------------------------------
# Copy to /etc/quirk/console.env, fill in the values, then:
#   sudo chown root:quirk /etc/quirk/console.env
#   sudo chmod 640 /etc/quirk/console.env       # secrets — not world-readable
#
# Loaded by the systemd unit (EnvironmentFile=/etc/quirk/console.env).
# See docs/deployment-cloud-console.md for the full walkthrough.
# -----------------------------------------------------------------------------

# REQUIRED — operator/dashboard API token. Governs CLI + dashboard access.
# Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
QUIRK_API_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_VALUE

# Trusted reverse-proxy source IP(s), comma-separated, or "*" to trust all
# upstreams. With the proxy on the SAME host (recommended), loopback is correct:
# uvicorn then reads the real sensor IP from X-Forwarded-For for correct rate
# limiting and audit logging. Only widen this if the proxy is on another host.
QUIRK_TRUST_PROXY=127.0.0.1

# Emit HTTP Strict-Transport-Security. Safe to enable because the reverse proxy
# terminates TLS in front of the console. Leave unset for plain-HTTP local runs.
QUIRK_HSTS=1

# CORS allowlist for the dashboard SPA — set to the public origin(s) operators
# use in the browser. Comma-separated. Defaults to localhost when unset.
QUIRK_CORS_ORIGINS=https://quirk.example.com

# OPTIONAL — defense-in-depth network allowlist for sensor pushes. Comma-
# separated IPs / CIDRs of your sensors' egress addresses. Leave unset to allow
# any source (per-sensor token auth still applies regardless).
# QUIRK_SENSOR_IP_ALLOWLIST=203.0.113.4,198.51.100.0/24

# Path to the scan/merge config.yaml the console reads (auto-merge, etc.).
QUIRK_CONFIG_PATH=/etc/quirk/config.yaml
