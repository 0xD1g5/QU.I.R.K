<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {# Phase 78 / HARDEN-04: constant title for PDF metadata — do not interpolate scanner/operator content #}
  <title>QU.I.R.K. Cryptographic Readiness Report</title>
  <meta name="author" content="QU.I.R.K. Scanner">
  <style>
    /* === QU.I.R.K. Report Stylesheet — all CSS embedded, no external refs === */
    :root {
      --bg: #0a0a0f;
      --surface: #12121a;
      --surface2: #1a1a26;
      --border: #2a2a3a;
      --accent: #3b9dff;
      --text: #e8e8f0;
      --text-muted: #8888aa;
      --critical: #e53935;
      --high: #f57c00;
      --medium: #f9a825;
      --low: #5c9cff;
      --info: #666688;
      --green: #4caf50;
      --amber: #f9a825;
      --red: #e53935;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Courier New', Courier, monospace;
      font-size: 14px;
      line-height: 1.6;
      padding: 0;
    }
    a { color: var(--accent); text-decoration: none; }
    .report-header {
      background: var(--surface);
      border-bottom: 2px solid var(--accent);
      padding: 24px 40px;
      display: flex;
      align-items: baseline;
      gap: 20px;
    }
    .wordmark {
      font-size: 28px;
      font-weight: 900;
      letter-spacing: 0.12em;
      color: var(--accent);
      font-family: 'Courier New', Courier, monospace;
    }
    .report-meta {
      color: var(--text-muted);
      font-size: 12px;
    }
    .report-body { max-width: 1100px; margin: 0 auto; padding: 40px; }
    section { margin-bottom: 56px; }
    h1 { font-size: 22px; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 24px; }
    h2 { font-size: 17px; color: var(--text); margin: 24px 0 12px; }
    h3 { font-size: 14px; color: var(--text-muted); margin: 16px 0 8px; }
    .score-card {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      background: var(--surface);
      border: 2px solid {{ score_color }};
      border-radius: 8px;
      padding: 24px 40px;
      margin-bottom: 24px;
    }
    .score-value { font-size: 56px; font-weight: 900; color: {{ score_color }}; line-height: 1; }
    .score-band { font-size: 16px; color: {{ score_color }}; margin-top: 4px; letter-spacing: 0.1em; }
    .score-label { font-size: 11px; color: var(--text-muted); margin-top: 4px; }
    .sev-grid { display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0; }
    .sev-badge {
      padding: 8px 16px;
      border-radius: 4px;
      font-size: 13px;
      font-weight: bold;
      min-width: 80px;
      text-align: center;
    }
    .sev-CRITICAL { background: var(--critical); color: #fff; }
    .sev-HIGH { background: var(--high); color: #fff; }
    .sev-MEDIUM { background: var(--medium); color: #111; }
    .sev-LOW { background: var(--low); color: #fff; }
    .sev-INFO { background: var(--info); color: #ddd; }
    table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 13px; }
    th {
      background: var(--surface2);
      color: var(--accent);
      text-align: left;
      padding: 8px 12px;
      font-weight: 600;
      border-bottom: 1px solid var(--border);
    }
    td { padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--surface2); }
    .sev-cell { font-weight: bold; font-size: 11px; padding: 2px 6px; border-radius: 3px; }
    .roadmap-phase { margin: 16px 0; }
    .roadmap-phase h3 { color: var(--accent); text-transform: uppercase; font-size: 13px; letter-spacing: 0.1em; }
    .roadmap-item {
      background: var(--surface);
      border-left: 3px solid var(--accent);
      padding: 10px 16px;
      margin: 8px 0;
      border-radius: 0 4px 4px 0;
    }
    .roadmap-item strong { color: var(--text); }
    .roadmap-item span { color: var(--text-muted); font-size: 12px; }
    .drivers-list { list-style: none; }
    .drivers-list li::before { content: "▸ "; color: var(--accent); }
    .drivers-list li { padding: 3px 0; color: var(--text-muted); font-size: 13px; }
    .meta-table td:first-child { color: var(--text-muted); width: 180px; }
    .meta-table td:last-child { color: var(--text); }
    .footer {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 16px 40px;
      text-align: center;
      color: var(--text-muted);
      font-size: 11px;
    }
    /* Phase 98 — Narrative prose block (EXEC-01) */
    .narrative-block {
      background: var(--surface);
      border-left: 3px solid var(--accent);
      border-radius: 0 4px 4px 0;
      padding: 16px 24px;
      margin-bottom: 24px;
      font-size: 14px;
      line-height: 1.6;
      color: var(--text);
    }
    .narrative-block p + p { margin-top: 8px; }
    /* Phase 98 — Top-risks list (EXEC-02, extends .drivers-list pattern) */
    .risks-list { list-style: none; margin: 0; padding: 0; }
    .risks-list li {
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
      line-height: 1.5;
    }
    .risks-list li:last-child { border-bottom: none; }
    /* Color differentiates risk label from impact text — no weight change (UI-SPEC) */
    .risks-list .risk-label { color: var(--text); margin-right: 4px; }
    .risks-list .risk-impact { color: var(--text-muted); }
    /* Phase 98 — Rollup formula block (TRANS-02) */
    .rollup-formula {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 8px 16px;
      margin: 8px 0 24px;
      font-size: 13px;
      color: var(--text-muted);
    }
    .rollup-formula strong { color: var(--text); }
    /* Phase 98 — Roadmap priority indicator (EXEC-03) */
    /* Reuses 12px label/meta size; uppercase + letter-spacing provides visual distinction */
    .priority-label {
      display: inline-block;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 4px;
    }
    /* Phase 99 — Quantum Risk inline block (Top Findings summary table) */
    .quantum-risk-block {
      margin-top: 4px;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text-muted);
    }
    /* Phase 99 — Quantum Risk label tag (inline prefix) */
    .quantum-risk-label {
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      margin-right: 4px;
    }

    /* === Phase 100 — PDF Cover Page (FMT-01) === */

    /* Cover page: full A4-page block, dark background, accent top border */
    .cover-page {
      background: var(--bg);
      border-top: 4px solid var(--accent);
      min-height: 100vh;           /* fills page in screen view */
      padding: 48px 40px 32px;
      display: flex;
      flex-direction: column;
      box-sizing: border-box;
    }

    /* Logo region — conditionally rendered (omitted when logo absent, D-03) */
    .cover-logo-region {
      margin-bottom: 32px;
    }
    .cover-logo-region img {
      max-width: 200px;
      max-height: 80px;
      object-fit: contain;
      display: block;
    }

    /* Cover title — the report's primary display heading */
    .cover-title {
      font-size: 36px;
      font-weight: 900;
      color: var(--accent);
      letter-spacing: 0.04em;
      line-height: 1.1;
      margin-bottom: 16px;
    }

    /* Organization name — directly below title */
    .cover-org-name {
      font-size: 22px;
      font-weight: 400;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 0;
    }

    /* Lower metadata block — pushed toward the bottom of the cover page */
    .cover-meta-block {
      margin-top: auto;         /* flexbox: fills remaining space, pushes block down */
      border-top: 1px solid var(--border);
      background: var(--surface);
      padding: 16px 24px;
      border-radius: 4px;
    }
    .cover-meta-label {
      font-size: 12px;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      display: inline-block;
      width: 160px;
    }
    .cover-meta-value {
      font-size: 12px;
      font-weight: 400;
      color: var(--text);
    }
    .cover-meta-row {
      margin-bottom: 8px;
    }
    .cover-meta-row:last-child { margin-bottom: 0; }

    /* Classification banner — full-width badge at the bottom of the cover */
    .cover-classification-banner {
      margin-top: 24px;
      padding: 8px 16px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      text-align: center;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text);
    }

    /* === Phase 100 — PDF Print & Pagination (FMT-02) === */

    /* 7-column findings table: fixed layout, explicit widths, word-wrap within cells */
    table.findings-table {
      table-layout: fixed;
      width: 100%;
    }
    table.findings-table th,
    table.findings-table td {
      word-wrap: break-word;
      overflow-wrap: break-word;
      vertical-align: top;
    }
    /* Column headers are short fixed labels — never let them wrap mid-word
       ("Severity" → "Severit y"). Data cells keep break-word above. */
    table.findings-table th { white-space: nowrap; }
    /* Per-column width contract (A4 printable width ~170mm after 12mm L/R margins).
       Severity/Port widened so their header labels fit on one line. */
    table.findings-table th:nth-child(1),
    table.findings-table td:nth-child(1) { width: 10%; }
    table.findings-table th:nth-child(2),
    table.findings-table td:nth-child(2) { width: 20%; }
    table.findings-table th:nth-child(3),
    table.findings-table td:nth-child(3) { width: 11%; }
    table.findings-table th:nth-child(4),
    table.findings-table td:nth-child(4) { width: 7%; }
    table.findings-table th:nth-child(5),
    table.findings-table td:nth-child(5) { width: 22%; }
    table.findings-table th:nth-child(6),
    table.findings-table td:nth-child(6) { width: 18%; }
    table.findings-table th:nth-child(7),
    table.findings-table td:nth-child(7) { width: 12%; }

    @media print {
      @page { size: A4; margin: 15mm 12mm; }
      .cover-page { break-after: page; }
      h1 { break-after: avoid; }
      h2 { break-after: avoid; }
      tr { break-inside: avoid; }
      thead { display: table-header-group; }
      /* Suppress screen-only decorations in print */
      .report-header { display: none; }
      .footer { display: none; }
      .report-body { padding: 0; max-width: 100%; }
    }
  </style>
</head>
<body>

<header class="report-header">
  <span class="wordmark">QU.I.R.K.</span>
  <span class="report-meta">Quantum Readiness Report &nbsp;|&nbsp; {{ org_name | sanitize }} &nbsp;|&nbsp; {{ generated_at }}</span>
</header>

<div class="report-body">

  {# Phase 100 / FMT-01 / D-01..D-04: PDF Cover Page — inserted BEFORE all sections.
     Occupies its own printed page (break-after: page in @media print).
     logo_b64 is None when logo_path absent/unreadable (D-03): omit logo region entirely.
     All config values are sanitized — they are user-supplied strings.
  #}
  <div class="cover-page">

    {% if logo_b64 %}
    <div class="cover-logo-region">
      <img src="data:image/{{ logo_mime }};base64,{{ logo_b64 }}"
           alt="{{ org_name | sanitize }} logo">
    </div>
    {% endif %}

    <div class="cover-title">QU.I.R.K. Cryptographic Readiness Report</div>
    <div class="cover-org-name">{{ org_name | sanitize }}</div>

    <div class="cover-meta-block">
      <div class="cover-meta-row">
        <span class="cover-meta-label">Report Owner</span>
        <span class="cover-meta-value">{{ report_owner | sanitize }}</span>
      </div>
      <div class="cover-meta-row">
        <span class="cover-meta-label">Scan Date</span>
        <span class="cover-meta-value">{{ generated_at }}</span>
      </div>
      <div class="cover-meta-row">
        <span class="cover-meta-label">Data Classification</span>
        <span class="cover-meta-value">{{ data_classification | sanitize }}</span>
      </div>
      <div class="cover-classification-banner">{{ data_classification | upper | sanitize }}</div>
    </div>

  </div><!-- /cover-page -->

  <!-- ===== EXECUTIVE SUMMARY ===== -->
  <section id="executive-summary">
    <h1>Executive Summary</h1>

    <table class="meta-table" style="width:auto;margin-bottom:24px;">
      <tr><td>Organization</td><td>{{ org_name | sanitize }}</td></tr>
      <tr><td>Report owner</td><td>{{ report_owner | sanitize }}</td></tr>
      <tr><td>Data classification</td><td>{{ data_classification | sanitize }}</td></tr>
      <tr><td>Generated</td><td>{{ generated_at }}</td></tr>
    </table>

    {# Phase 98 / EXEC-01 / D-03: Narrative prose block from exec_content.narrative_lead.
       Positioned before the score card per RESEARCH "Required order after Phase 98".
       narrative_lead is static prose from _NARRATIVE_LEADS — no sanitize needed.
       narrative_drivers come from score_raw["drivers"] (reason strings) — sanitize applied. #}
    {% if narrative_lead %}
    <div class="narrative-block">
      <h2>Readiness Assessment</h2>
      {# narrative_lead is static prose from _NARRATIVE_LEADS — mark safe (no user input) #}
      <p>{{ narrative_lead | safe }}</p>
      {% if narrative_drivers %}
      {# narrative_drivers come from score_raw["drivers"] — sanitize scanner-derived text #}
      <p>Key factors: {{ narrative_drivers | join('; ') | sanitize }}</p>
      {% endif %}
    </div>
    {% endif %}

    <h2>Quantum Readiness Score</h2>
    <div class="score-card">
      <div class="score-value">{{ total_score }}</div>
      <div class="score-band">{{ score_band }}</div>
      <div class="score-label">/ 100 &nbsp;|&nbsp; Confidence: {{ confidence }}/100</div>
    </div>

    {% if subscores %}
    <h3>Score Decomposition</h3>
    <table>
      <thead><tr><th>Category</th><th>Score</th><th>Budget</th></tr></thead>
      <tbody>
        <tr><td>Hygiene</td><td>{{ subscores.get('hygiene', '—') }}</td><td>/25</td></tr>
        <tr><td>Modern TLS</td><td>{{ subscores.get('modern_tls', '—') }}</td><td>/25</td></tr>
        <tr><td>Identity</td><td>{{ subscores.get('identity_trust', '—') }}</td><td>/25</td></tr>
        <tr><td>Agility</td><td>{{ subscores.get('agility_signals', '—') }}</td><td>/25</td></tr>
        <tr><td>Data at Rest</td><td>{{ subscores.get('data_at_rest', '—') }}</td><td>/25</td></tr>
        <tr><td>Data in Motion</td><td>{{ subscores.get('data_in_motion', '—') }}</td><td>/25</td></tr>
      </tbody>
    </table>
    <p><strong>Rollup:</strong>
      {# WR-03 / IN-01: use the shared pre-computed numerator so HTML and CLI agree (and a
         future 7th subscore can't silently diverge the two surfaces). #}
      {{ raw_sum }} &divide; 1.5 = <strong>{{ total_score }} / 100</strong>
    </p>
    {# Phase 98 / TRANS-02 / D-03: Rollup formula explanation block — static prose, no sanitize.
       Sourced from UI-SPEC Copywriting Contract exact strings. #}
    <div class="rollup-formula">
      <strong>How this score was computed</strong><br>
      Six pillar subscores (each /25) are summed and divided by 1.5 to produce a 0&ndash;100 readiness score.
    </div>
    {% endif %}

    {# Phase 98 / EXEC-02 / D-03: Priority Business Risks from exec_content.top_risks (D-02 static map).
       risk_label and impact_sentence come from ALGO_IMPACT_MAP — static strings, no sanitize needed. #}
    {% if top_risks %}
    <h2>Priority Business Risks</h2>
    <ul class="risks-list">
      {% for risk in top_risks %}
      <li>
        <span class="risk-label">{{ risk.risk_label }}</span>
        <span class="risk-impact">{{ risk.impact_sentence }}</span>
      </li>
      {% endfor %}
    </ul>
    {% endif %}

    <h2>Findings Breakdown</h2>
    <div class="sev-grid">
      {% for sev in ['CRITICAL','HIGH','MEDIUM','LOW','INFO'] %}
        {% if sev_counts.get(sev, 0) > 0 %}
        <div class="sev-badge sev-{{ sev }}">{{ sev }}: {{ sev_counts.get(sev, 0) }}</div>
        {% endif %}
      {% endfor %}
      {% if not sev_counts %}
      <span style="color:var(--text-muted)">No findings</span>
      {% endif %}
    </div>

    {% if drivers %}
    <h2>Score Drivers</h2>
    <ul class="drivers-list">
      {% for d in drivers %}<li>{{ d | sanitize }}</li>{% endfor %}
    </ul>
    {% endif %}

    {% if findings %}
    <h2>Top Findings</h2>
    {# Phase 78 / HARDEN-02..03: every scanner-controlled cell piped through | sanitize. autoescape covers metachar escape; sanitize strips embedded tags/URLs. #}
    <table>
      <thead><tr><th>Severity</th><th>Title</th><th>Host</th><th>Description</th></tr></thead>
      <tbody>
      {% for f in (findings | rejectattr('category', 'equalto', 'coverage_gap') | list)[:10] %}
      <tr>
        <td><span class="sev-cell sev-{{ f.get('severity','INFO')|upper }}">{{ f.get('severity','INFO')|upper }}</span></td>
        <td>{{ f.get('title','') | sanitize }}</td>
        <td>{{ f.get('host','') | sanitize }}{% if f.get('port') %}:{{ f.get('port') }}{% endif %}</td>
        <td>{{ f.get('description','')[:120] | sanitize }}{% if f.get('description','')|length > 120 %}…{% endif %}
        {# Phase 99 CTX-01 / D-03: quantum_risk block inside Description cell (no new column).
           Gated on presence of quantum_risk so findings without the field remain unchanged.
           quantum_risk is scanner-derived text — must pass through | sanitize (T-99-06). #}
        {% if f.get('quantum_risk') %}<div class="quantum-risk-block"><span class="quantum-risk-label">Quantum Risk:</span>{{ f.get('quantum_risk','')[:120] | sanitize }}</div>{% endif %}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}

    <h2>Transition Roadmap</h2>
    {% for phase_label, items in [('NOW', roadmap_now), ('NEXT', roadmap_next), ('LATER', roadmap_later)] %}
    {% if items %}
    <div class="roadmap-phase">
      <h3>{{ phase_label }}</h3>
      {% for item in items %}
      <div class="roadmap-item">
        {# Phase 98 / EXEC-03 / D-03: item is RoadmapItem dataclass (with .title/.why/.effort/.impact)
           when exec_content is provided; falls back to raw dict when not. Jinja2 resolves
           item.title via getattr-then-item-lookup so both cases work transparently. #}
        <strong>{{ item.title | sanitize }}</strong><br>
        <span>{{ item.why | sanitize }}</span>
        {# Priority labels: effort/impact from D-05 EFFORT_IMPACT_MAP — static strings, no sanitize.
           Only rendered when item carries effort/impact (RoadmapItem dataclass path). #}
        {% if item.effort is defined and item.effort %}
        <br><span class="priority-label">{{ item.effort }} EFFORT &nbsp;&middot;&nbsp; {{ item.impact }} IMPACT</span>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% endfor %}
  </section>

  <!-- ===== TECHNICAL APPENDIX ===== -->
  <section id="technical-appendix">
    <h1>Technical Appendix</h1>

    {% set coverage_gaps = findings | selectattr('category', 'equalto', 'coverage_gap') | list %}
    {% if coverage_gaps %}
    <h2>Coverage Gaps</h2>
    <p style="color:var(--text-muted)">Scanners that were enabled in config but skipped because their optional extra is not installed. These advisories do not affect the readiness score.</p>
    <table>
      <thead><tr><th>Scanner</th><th>Recommendation</th></tr></thead>
      <tbody>
      {% for f in coverage_gaps %}
      <tr><td>{{ f.get('host','') | sanitize }}</td><td>{{ f.get('recommendation','') | sanitize }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}

    <h2>All Findings</h2>
    {% if findings %}
    {# Phase 99 CTX-01 / D-03: FALLBACK_QR constant — mirrors FALLBACK_QUANTUM_RISK in content_model.py. #}
    {% set FALLBACK_QR = "This cryptographic weakness reduces the security margin against quantum-capable adversaries. Migrate to NIST-approved post-quantum algorithms per NIST IR 8547." %}
    <table class="findings-table">
      <thead><tr><th>Severity</th><th>Title</th><th>Host</th><th>Port</th><th>Description</th><th>Recommendation</th><th>Quantum Risk</th></tr></thead>
      <tbody>
      {% for f in findings if f.get('category') != 'coverage_gap' %}
      <tr>
        <td><span class="sev-cell sev-{{ f.get('severity','INFO')|upper }}">{{ f.get('severity','INFO')|upper }}</span></td>
        <td>{{ f.get('title','') | sanitize }}</td>
        <td>{{ f.get('host','') | sanitize }}</td>
        <td>{{ f.get('port','') }}</td>
        <td>{{ f.get('description','')[:200] | sanitize }}{% if f.get('description','')|length > 200 %}…{% endif %}</td>
        <td>{{ f.get('recommendation','')[:200] | sanitize }}{% if f.get('recommendation','')|length > 200 %}…{% endif %}</td>
        {# Phase 99 CTX-01: Quantum Risk column as 7th column per UI-SPEC §Interaction Contract (WR-01 fix). #}
        <td><span class="quantum-risk-label">Quantum Risk:</span>{{ f.get('quantum_risk', FALLBACK_QR)[:200] | sanitize }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="color:var(--text-muted)">No findings recorded for this scan.</p>
    {% endif %}

    {# ── Phase 49 D-03: Compliance Summary section (framework-grouped tables) ── #}
    <h2>Compliance Summary</h2>
    <p style="color:var(--text-muted)">
      Findings mapped to compliance control references. Use these as evidence input
      for PCI-DSS, HIPAA, and FIPS 140-3 assessments. See
      <code>docs/report-interpretation.md</code> for assessor handoff guidance.
    </p>
    {% set _frameworks = ['PCI-DSS 4.0.1', 'HIPAA 45 CFR', 'FIPS 140-3'] %}
    {% for fw in _frameworks %}
      {% set _rows = [] %}
      {% for f in findings if f.get('category') != 'coverage_gap' %}
        {% for c in f.get('compliance', []) if c.get('framework') == fw %}
          {% set _ = _rows.append((f, c)) %}
        {% endfor %}
      {% endfor %}
      <h3>{{ fw }}</h3>
      {% if _rows %}
      <table>
        <thead><tr><th>Severity</th><th>Finding</th><th>Control</th><th>Source</th></tr></thead>
        <tbody>
        {% for f, c in _rows %}
        <tr>
          <td><span class="sev-cell sev-{{ f.get('severity','INFO')|upper }}">{{ f.get('severity','INFO')|upper }}</span></td>
          <td>{{ f.get('title','') | sanitize }}</td>
          <td>{{ c.get('control','') }} ({{ c.get('version','') }})</td>
          <td><a href="{{ c.get('source_url','') | sanitize }}">link</a> &middot; verified {{ c.get('last_verified','') }}</td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p style="color:var(--text-muted)">No findings mapped to {{ fw }}.</p>
      {% endif %}
    {% endfor %}

    {# ── Coverage-gap surfacing per D-03 — findings without any compliance mapping ── #}
    {% set _unmapped = [] %}
    {% for f in findings if f.get('category') != 'coverage_gap' %}
      {% if not f.get('compliance', []) %}
        {% set _ = _unmapped.append(f) %}
      {% endif %}
    {% endfor %}
    {% if _unmapped %}
    <h3>Findings without compliance mapping</h3>
    <p style="color:var(--text-muted)">
      These findings are not mapped to any compliance framework. Reviewer should
      confirm this is expected (informational findings, observability advisories)
      rather than a coverage gap in the compliance map.
    </p>
    <ul>
      {% for f in _unmapped %}<li>{{ f.get('title','') | sanitize }} ({{ f.get('host','') | sanitize }})</li>{% endfor %}
    </ul>
    {% else %}
    <h3>Findings without compliance mapping</h3>
    <p style="color:var(--text-muted)">All findings are mapped to at least one compliance framework.</p>
    {% endif %}

    <h2>Endpoint Inventory</h2>
    {% if endpoints %}
    <table>
      <thead><tr><th>Host</th><th>Port</th><th>Protocol</th><th>TLS Version</th><th>Cipher Suite</th><th>Cert Key</th></tr></thead>
      <tbody>
      {% for ep in endpoints %}
      <tr>
        <td>{{ ep.host | sanitize }}</td>
        <td>{{ ep.port }}</td>
        <td>{{ (ep.protocol or '') | sanitize }}</td>
        <td>{{ (ep.tls_version or '') | sanitize }}</td>
        <td>{{ (ep.cipher_suite or '') | sanitize }}</td>
        <td>{{ (ep.cert_pubkey_alg or '') | sanitize }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="color:var(--text-muted)">No endpoints recorded for this scan.</p>
    {% endif %}

    {# ── Phase 81 / CMVP-06 — Algorithm Inventory with FIPS 140-3 CMVP coverage.
         Every scanner-controlled cell wraps with `| sanitize` per the Phase 78
         chokepoint contract (see comment at line 176). The literal
         `Not in CMVP catalog` is template-static and not sanitized.
         v4.10-D-01 forbids active certification claims — use the "Not in CMVP catalog"
         literal only; do not introduce alternative wording. #}
    <h2>Algorithm Inventory (FIPS 140-3 Coverage)</h2>
    {% if algorithms %}
    <table>
      <thead><tr><th>Algorithm</th><th>NIST Level</th><th>FIPS Status</th><th>CMVP Coverage</th></tr></thead>
      <tbody>
      {% for a in algorithms %}
      <tr>
        <td>{{ a.name | sanitize }}</td>
        <td>{{ a.nist_level }}</td>
        <td>{{ a.fips_status | sanitize }}</td>
        <td>{{ a.cmvp_coverage | sanitize if a.cmvp_coverage else 'Not in CMVP catalog' }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </section>

</div><!-- /report-body -->

<footer class="footer">
  Generated by <strong>QU.I.R.K.</strong> Quantum Infrastructure Readiness Kit &nbsp;|&nbsp; {{ generated_at }}
</footer>

</body>
